# Sahayak AI — Environment Variables
# Copy to .env and fill in values for local development

# AWS Configuration
AWS_REGION=ap-south-1
AWS_PROFILE=sahayak-dev

# DynamoDB Tables
SESSIONS_TABLE=sahayak-dev-sessions
USERS_TABLE=sahayak-dev-users
SCHEMES_TABLE=sahayak-dev-schemes
RULES_TABLE=sahayak-dev-eligibility-rules
AUDIT_TABLE=sahayak-dev-audit-log

# OpenSearch
OPENSEARCH_ENDPOINT=search-sahayak-dev-xxx.ap-south-1.es.amazonaws.com

# S3 Buckets
AUDIO_INPUT_BUCKET=sahayak-dev-audio-input-123456789
AUDIO_OUTPUT_BUCKET=sahayak-dev-audio-output-123456789
SCHEMES_BUCKET=sahayak-dev-scheme-docs-123456789
TRANSCRIPT_BUCKET=sahayak-dev-transcripts

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Lambda Function Names (for local invocation testing)
STT_FUNCTION_NAME=sahayak-dev-voice-stt
TTS_FUNCTION_NAME=sahayak-dev-voice-tts
RETRIEVAL_FUNCTION_NAME=sahayak-dev-scheme-retrieval
ELIGIBILITY_FUNCTION_NAME=sahayak-dev-eligibility-engine

# Cognito
COGNITO_USER_POOL_ID=ap-south-1_xxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Logging
LOG_LEVEL=DEBUG
